import random
import string

length = int(input("Enter the length of your password(8 - 32): "))

while(True):
    if length < 8:
        print("You must enter a password length between 8 - 32 ")
        print()
        length = int(input("Enter the length of your password(8 - 32): "))
    elif length > 32:
        print("You must enter a password length between 8 - 32 ")
        print()
        length = int(input("Enter the length of your password(8 - 32): "))
    else:
        print()
        break

print('''Choose one or more character set for password from these :
            1. Number password
            2. Letter password
            3. Symbol
            4. Quit''')

randomchar = ""
l = 0
s = 0
n = 0

while(True):
    option = int(input("Choose a option(1, 2, 3, or 4): "))
    
    if option == 1:
        n += 1
        
    elif option == 2:
        l += 1
        
    elif option == 3:
        s += 1
        
    elif option == 4:
        break

    else:
        print("Enter a valid number! ")
while(True):        
    l1 = int(input("Enter how many letters you want: "))
    n1 = int(input("Enter how many numbers you want: "))
    s1 = int(input("Enter how many symbols you want: "))
    if l1 + n1 + s1 != length:
        print("That does not add up to " + str(length))
    else:
        break

password = []

if l > 0:
    for i in range(l1):
        password.append(random.choice(string.ascii_letters))
if n > 0:
    for i in range(n1):
        password.append(random.choice(string.digits))
if s > 0:
    for i in range(s1):
        password.append(random.choice(string.punctuation))


