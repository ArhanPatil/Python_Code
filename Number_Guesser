"""
TITLE: Number_Guesser

"""
import random
a = random. randrange(1,10)
i = 3
while i != 0:
    try:
        guess = input("Guess a number between 1-10 ")
        if int(guess) == int(a):
            print("Correct! Answer is " + str(a))
            i = 0
        else:
            print("Try again! ")
    except:
        print("Enter a valid number!! ")
    
